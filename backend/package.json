{
  "name": "table-manager-backend",
  "version": "1.0.1",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "migrate:dev": "ts-node-dev --respawn --transpile-only src/migrate.ts",
    "build": "tsc -p .",
    "start": "node dist/index.js",
    "migrate": "node dist/migrate.js",
    "clean:test": "node cleanup-test-data.js"
  },
  "dependencies": {
    "prom-client": "^14.0.0",
    "@sentry/node": "^7.63.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.10.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.16.0",
    "@types/uuid": "^9.0.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
